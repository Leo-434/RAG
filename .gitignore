# ============================================================
#  GraphRAG — .gitignore
#  生成日期: 2026-03-29
# ============================================================

# ------------------------------------------------------------
# 🔑 敏感信息 / Secrets（绝对不能上传）
# ------------------------------------------------------------
.env
.env.local
.env.*.local
# 保留 .env.example 作为配置模板（不含真实密钥）

# ------------------------------------------------------------
# 📦 Python 依赖与虚拟环境
# ------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.dist-info/
pip-wheel-metadata/

# ------------------------------------------------------------
# 🗄️ 本地数据库与用户数据（包含用户私人内容）
# ------------------------------------------------------------
backend/data/
# 说明:
#   backend/data/chroma_db/    — ChromaDB 向量数据库（运行时生成）
#   backend/data/uploads/      — 用户上传的 PDF 文件
#   backend/data/conversations.db — 对话历史 + 文档元数据（SQLite）

# ------------------------------------------------------------
# 🌐 Node.js / 前端依赖与构建产物
# ------------------------------------------------------------
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
*.local

# ------------------------------------------------------------
# 🖥️ macOS 系统文件
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ------------------------------------------------------------
# 💡 IDE / 编辑器配置（个人本地配置，不共享）
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------------------------------------
# 🔧 Claude Code 会话文件
# ------------------------------------------------------------
.claude/

# ------------------------------------------------------------
# 🚀 Vite / 构建缓存
# ------------------------------------------------------------
.vite/
*.tsbuildinfo

# ------------------------------------------------------------
# 📋 日志文件
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# 🧪 测试缓存
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------
# 📝 其他临时文件
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
Thumbs.db


Test/
docs/
